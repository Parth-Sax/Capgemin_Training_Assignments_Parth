<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"

       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

       xsi:schemaLocation="
    http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="bean_id" class="ioc_with_xml.Laptop">
        <property name="price" value="11"></property>
        <property name="model" value="HP"></property>
        <property name="chipset" value="Intel"></property>
    </bean>
    <bean id="bean2" class="ioc_with_xml.Laptop">
        <property name="price" value="12"></property>
        <property name="model" value="Dell"></property>
        <property name="chipset" value="Ryzen"></property>
    </bean>
</beans>